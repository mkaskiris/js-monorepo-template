{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file .env --import tsx/esm --watch src/index.ts",
    "build": "tsc",
    "start": "node --env-file .env dist/index.js",
    "lint": "eslint .",
    "test": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:reset": "drizzle-kit drop"
  },
  "dependencies": {
    "@app/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.44.1",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "postgres": "^3.4.5",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^24.0.0",
    "@types/supertest": "^6.0.3",
    "drizzle-kit": "^0.30.4",
    "supertest": "^7.2.2",
    "tsx": "^4.19.4",
    "typescript": "~5.9.3",
    "vitest": "^4.0.18"
  }
}
